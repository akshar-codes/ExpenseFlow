# ─────────────────────────────────────────────────────────────────────────────
# ExpenseTracker — Backend Environment Variables
# Copy this file to .env and fill in all values before starting the server.
#
#   cp .env.example .env
#
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────


# ── Database ──────────────────────────────────────────────────────────────────

# MongoDB connection string (local or Atlas)
# Local:  mongodb://localhost:27017/expensetracker
# Atlas:  mongodb+srv://<user>:<password>@<cluster>.mongodb.net/expensetracker
MONGO_URI=mongodb://localhost:27017/expensetracker


# ── JWT Secrets ───────────────────────────────────────────────────────────────
# Both secrets must be at least 32 characters.
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"

JWT_ACCESS_SECRET=replace_with_a_random_string_min_32_chars
JWT_REFRESH_SECRET=replace_with_a_different_random_string_min_32_chars


# ── Server ────────────────────────────────────────────────────────────────────

PORT=5000

# "development" | "production" | "test"
NODE_ENV=development


# ── CORS ─────────────────────────────────────────────────────────────────────
# Origin of the frontend application (no trailing slash)
CLIENT_URL=http://localhost:5173


# ── Security ─────────────────────────────────────────────────────────────────

# bcrypt cost factor — 10 is a safe default; increase for higher security at
# the cost of hashing time (12–14 for production).
BCRYPT_ROUNDS=10

# Maximum login attempts per IP within the 15-minute window
RATE_LIMIT_LOGIN_MAX=5

# Maximum registration attempts per IP within the 1-hour window
RATE_LIMIT_REGISTER_MAX=10
