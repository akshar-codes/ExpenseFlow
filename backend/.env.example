# ─────────────────────────────────────────────────────────────────────────────
# ExpenseTracker — Backend Environment Variables
# Copy this file to .env and fill in all values before starting the server.
#
#   cp .env.example .env
#
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# MongoDB connection string
MONGO_URI=mongodb://localhost:27017/expensetracker

# JWT Secrets — must be at least 32 characters each
# Generate: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_ACCESS_SECRET=replace_with_a_random_string_min_32_chars
JWT_REFRESH_SECRET=replace_with_a_different_random_string_min_32_chars

# Server
PORT=5000
NODE_ENV=development

# Frontend origin for CORS (no trailing slash)
CLIENT_URL=http://localhost:5173

# bcrypt cost factor — minimum 10, recommended 12 for production
BCRYPT_ROUNDS=10

# Rate limiting
RATE_LIMIT_LOGIN_MAX=5
RATE_LIMIT_REGISTER_MAX=10

# Optional: protect the /health/details endpoint
HEALTH_SECRET=your_health_secret_here
